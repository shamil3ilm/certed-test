# ── Quick start: run locally in MOCK MODE (no Supabase / Google needed) ───────
# Copy this file to .env.local and `npm run dev`. The portal runs against a
# JSON-file fake of Supabase; sign in at /login with a demo account
# (e.g. admin@mock.test / cert-ed — also teacher@, mentor@, student@mock.test).
# See docs/setup_guide.md to go live.
MOCK_MODE=1
NEXT_PUBLIC_MOCK_MODE=1
NEXT_PUBLIC_SUPABASE_URL=http://mock.local        # sentinel so the env-guards treat the portal as configured
NEXT_PUBLIC_SUPABASE_ANON_KEY=mock-anon-key       # sentinel (unused in mock mode)
APP_HOSTNAME=app.certedacademia.com
MARKETING_HOSTNAME=certedacademia.com
# MOCK_PASSWORD=cert-ed                            # shared password for the seeded demo users (optional)
# MOCK_CHROME_PATH=                                # Chrome path for finance-PDF rendering in dev (optional)

# ── Production: Supabase (set these real values and MOCK_MODE=0) ───────────────
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=                       # server only — never expose to the client
# SEED_ADMIN_EMAIL=                                # used only by the first-admin seed command
# CRON_SECRET=                                     # protects /api/cron/*

# ── Marketing contact form (optional) ─────────────────────────────────────────
# GOOGLE_SCRIPT_URL=                               # Google Apps Script web app for the contact form

# ── Google Drive Picker for submissions (optional) ────────────────────────────
# Adds a one-click "Attach from Drive" button to the submit form; files go to
# each student's own Drive. Leave unset to keep the manual paste-a-link flow.
# Client-side keys, public by design — lock them to your origin + the Picker/Drive
# APIs in Google Cloud. Does NOT run in mock mode. Sign-in stays inside Supabase.
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=                    # OAuth 2.0 Web client ID
# NEXT_PUBLIC_GOOGLE_API_KEY=                      # API key with the Picker API enabled
# NEXT_PUBLIC_GOOGLE_APP_ID=                       # Google Cloud project number
